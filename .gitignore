# ============================================
# BMTS - Root .gitignore
# ============================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
venv/
.venv/
env/

# ---- Node.js ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- 前端构建产物 ----
bmts-frontend/dist/

# ---- 环境配置（含敏感信息）----
.env
.env.local
.env.*.local

# ---- 数据库文件 ----
*.db
*.sqlite3

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- 操作系统 ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- 日志 ----
*.log
logs/

# ---- 临时文件 ----
*.tmp
*.temp
.cache/
